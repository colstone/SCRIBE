{
  "identifier": "default",
  "description": "Default permissions for SCRIBE",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-read-dir",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "python-sidecar", "cmd": "python", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "python-sidecar", "cmd": "python", "args": true }
      ]
    },
    "shell:allow-stdin-write",
    "core:webview:allow-set-webview-zoom",
    "core:window:allow-set-title"
  ]
}
